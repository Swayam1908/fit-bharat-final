# ─────────────────────────────────────────────────────────────────
# FitBharat Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Next.js ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars-here

# ── Supabase ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Prisma / Database ─────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → Database
#
# Transaction mode pooler (used by Prisma in serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#
# Direct connection (used by prisma migrate / db push)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Google AI (Gemini — for meal parsing) ─────────────────────────
# Optional: enables AI meal description → macro parsing
GOOGLE_AI_API_KEY=AIza...

# ── Email (optional — for password reset emails) ──────────────────
# Example using Resend (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@fitbharat.com
