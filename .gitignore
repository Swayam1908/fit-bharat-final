# FitBharat Production Gitignore template

# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage
/tests/results
/tests/reports

# Production Next.js builds
/.next/
/out/

# Production output bundles
/dist
/build

# Environment files and Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# System/IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Gzip/Pack assets
*.pack.gz
.next/cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
